<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:harmonyos="http://schemas.harmonyos.com/apk/res/harmonyos">

    <!-- HarmonyOS Compatibility: This APK supports both Android and HarmonyOS devices -->
    <!-- On HarmonyOS 4.x, Android APKs run through the Android compatibility layer -->
    <!-- On HarmonyOS NEXT, a separate HAP package would be needed -->

    <application
        android:allowBackup="true"
        tools:replace="android:allowBackup"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="false"
        android:enableOnBackInvokedCallback="true"
        android:resizeableActivity="true">

        <!-- Huawei HMS Core App ID -->
        <meta-data
            android:name="com.huawei.hms.client.appid"
            android:value="appid=6917605804441958013" />

        <!-- Huawei Analytics -->
        <meta-data
            android:name="com.huawei.hms.client.analytics.enabled"
            android:value="true" />

        <!-- Huawei Ads - Enable ads tracking -->
        <meta-data
            android:name="com.huawei.hms.support.ads.disableAdvertisingId"
            android:value="false" />

        <!-- HarmonyOS compatibility metadata -->
        <meta-data
            android:name="com.huawei.harmonyos.compat.enabled"
            android:value="true" />
        <meta-data
            android:name="com.huawei.harmonyos.compat.mode"
            android:value="android-compat" />

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Required for Huawei HMS IAP & Ads Kit -->
    <uses-permission android:name="com.huawei.app.market.service.commondata.permission.GET_COMMON_DATA" />
    <!-- Required for Huawei Push -->
    <uses-permission android:name="android.permission.RECEIVE_PUSH_MESSAGES" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- HarmonyOS & Android Feature Declarations -->
    <!-- Touchscreen is required for game interaction -->
    <uses-feature android:name="android.hardware.touchscreen" android:required="true" />
    <!-- Network is required for online features -->
    <uses-feature android:name="android.hardware.wifi" android:required="false" />
    <!-- OpenGL ES 2.0 for WebView rendering -->
    <uses-feature android:glEsVersion="0x00020000" android:required="true" />
</manifest>
