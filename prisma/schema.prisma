generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String   @default("لاعب")
  password      String?
  avatar        String   @default("🦁")
  level         Int      @default(1)
  xp            Int      @default(0)
  coins         Int      @default(100)
  gems          Int      @default(5)
  totalScore    Int      @default(0)
  gamesPlayed   Int      @default(0)
  gamesWon      Int      @default(0)
  currentStreak Int      @default(0)
  bestStreak    Int      @default(0)
  role          String   @default("user") // "user" or "admin"
  provider      String   @default("credentials") // "credentials" or "google"
  googleId      String?
  dailyCompleted Boolean @default(false)
  dailyScore    Int      @default(0)
  lastDailyDate String   @default("")
  lastLoginAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  teamId        String?
  team          Team?    @relation(fields: [teamId], references: [id])
  achievements  UserAchievement[]
  gameSessions  GameSession[]
  purchases     Purchase[]
}

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  logo        String   @default("⚔️")
  description String   @default("")
  totalScore  Int      @default(0)
  members     User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Achievement {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String
  icon        String
  category    String
  requirement Int      @default(1)
  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  user          User        @relation(fields: [userId], references: [id])
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  unlockedAt    DateTime    @default(now())

  @@unique([userId, achievementId])
}

model GameSession {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  mode         String
  category     String   @default("")
  score        Int      @default(0)
  correctCount Int      @default(0)
  totalCount   Int      @default(0)
  xpEarned     Int      @default(0)
  coinsEarned  Int      @default(0)
  duration     Int      @default(0)
  createdAt    DateTime @default(now())
}

model Package {
  id          String   @id @default(cuid())
  name        String
  description String
  icon        String   @default("📦")
  coins       Int      @default(0)
  gems        Int      @default(0)
  price       Float    @default(0)
  currency    String   @default("SAR")
  color       String   @default("from-yellow-500 to-amber-600")
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdConfig {
  id           String   @id @default(cuid())
  adType       String   @unique // "banner", "interstitial", "rewarded"
  isEnabled    Boolean  @default(false)
  frequency    Int      @default(3) // show every N games
  adUnitId     String   @default("")
  position     String   @default("bottom") // "bottom", "top", "between"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @default("")
}

model DailyChallenge {
  id        String   @id @default(cuid())
  userId    String
  day       String
  score     Int      @default(0)
  completed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, day])
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  packageId String
  amount    Float    @default(0)
  status    String   @default("pending") // "pending", "completed", "failed"
  createdAt DateTime @default(now())
}

model LeaderboardEntry {
  id        String   @id @default(cuid())
  userId    String   @unique
  score     Int      @default(0)
  weekly    Int      @default(0)
  monthly   Int      @default(0)
  updatedAt DateTime @updatedAt
}
